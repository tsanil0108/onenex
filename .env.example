# Copy this file to .env and fill in your own EmailJS keys.
# Free account: https://www.emailjs.com
# Without these, the contact form still works — it falls back to opening
# the visitor's email client (mailto:) instead of sending directly.

VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
